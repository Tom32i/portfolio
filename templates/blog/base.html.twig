{% extends 'base.html.twig' %}

{% block body_class 'blog' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('blog') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('blog') }}
{% endblock %}

{% block body %}
    {% include 'common/menu.html.twig' %}

    {% block header null %}

    {% block content_container %}
        <section class="content container">
            {% block content '' %}
        </section>
    {% endblock %}

    {% block footer %}
        <footer>
            <div class="container">
                <div class="author">
                    <h4>À propos de moi</h4>
                    <a href="{{ path('portfolio') }}">
                        <img width="64" height="64" class="round" src="{{ asset('/img/portrait.jpg') }}" alt="Thomas Jarrand">
                        Thomas Jarrand
                    </a>
                </div>
                <div class="articles">
                    <a class="title" href="{{ path('blog') }}">Tous les articles</a>
                    {{ render(controller('App\\Controller\\BlogController::latest', { max: 3 })) }}
                </div>
            </div>
        </footer>
    {% endblock %}
{% endblock %}
